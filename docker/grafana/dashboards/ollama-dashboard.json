{
  "title": "Ollama AI Metrics",
  "uid": "ollama-auto-dashboard",
  "panels": [
    {
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_total{gen_ai_token_type=\"total\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Token Usage Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__rate_interval])",
          "legendFormat": "Prompt Tokens",
          "refId": "A"
        },
        {
          "expr": "rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__rate_interval])",
          "legendFormat": "Completion Tokens",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Requests Per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(gen_ai_client_operation_seconds_count[$__rate_interval])",
          "legendFormat": "QPS",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Response Time Percentiles (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gen_ai_client_operation_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"}
}